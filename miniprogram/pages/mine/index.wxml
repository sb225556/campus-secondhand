<view class="container">
  <view class="user-card">
    <image class="user-avatar" src="{{userInfo.avatarUrl || '../../images/avatar.png'}}" />
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName || '用户'}}</text>
      <text class="user-id">ID: {{openid ? openid.slice(-8) : '未登录'}}</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="onMyItems">
      <image class="menu-icon" src="../../images/goods.png" />
      <text class="menu-text">我的发布</text>
      <image class="menu-arrow" src="../../images/arrow.svg" />
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="onMyFavorites">
      <image class="menu-icon" src="../../images/icons/usercenter.png" />
      <text class="menu-text">我的收藏</text>
      <image class="menu-arrow" src="../../images/arrow.svg" />
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="onAbout">
      <image class="menu-icon" src="../../images/setting.svg" />
      <text class="menu-text">关于我们</text>
      <image class="menu-arrow" src="../../images/arrow.svg" />
    </view>
  </view>

  <view class="version-info">
    <text>校园二手物交换 v1.0.0</text>
  </view>
</view>