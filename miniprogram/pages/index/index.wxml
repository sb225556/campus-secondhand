<view class="container">
  <view class="user-bar" bindtap="onUserTap">
    <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/avatar.png'}}" />
    <view class="user-info">
      <view class="user-name">{{userInfo.nickName || '点击登录'}}</view>
      <view class="user-desc">欢迎来到校园二手物</view>
    </view>
    <view class="user-arrow">›</view>
  </view>

  <view class="search-bar">
    <input class="search-input" placeholder="搜索二手物品" value="{{keyword}}" bindinput="onKeywordInput" bindconfirm="onSearch" />
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <scroll-view class="category-scroll" scroll-x>
    <view class="category-list">
      <view
        class="category-item {{currentCategory === '' ? 'active' : ''}}"
        bindtap="onCategoryChange"
        data-category=""
      >
        全部
      </view>
      <view
        wx:for="{{categories}}"
        wx:key="name"
        class="category-item {{currentCategory === item.name ? 'active' : ''}}"
        bindtap="onCategoryChange"
        data-category="{{item.name}}"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <view class="filter-bar">
    <view class="time-range">
      <view
        wx:for="{{timeRanges}}"
        wx:key="value"
        class="time-item {{currentTimeRange === item.value ? 'active' : ''}}"
        bindtap="onTimeRangeChange"
        data-range="{{item.value}}"
      >
        {{item.label}}
      </view>
    </view>
    <view class="sort-btn" bindtap="onSortToggle">
      <text>{{sortOrder === 'desc' ? '最新' : '最早'}}</text>
      <text class="sort-icon {{sortOrder === 'desc' ? 'down' : 'up'}}">▾</text>
    </view>
  </view>

  <scroll-view 
    class="item-list" 
    scroll-y 
    bindscrolltolower="onLoadMore"
    bindscrolltoupper="onRefresh"
    lower-threshold="100"
    upper-threshold="50"
  >
    <view class="item-card" wx:for="{{items}}" wx:key="_id" bindtap="onItemTap" data-id="{{item._id}}">
      <image class="item-image" src="{{item.images[0] || '../../images/default-goods-image.png'}}" mode="aspectFill" />
      <view class="item-info">
        <view class="item-name">{{item.name}}</view>
        <view class="item-category">{{item.category}}</view>
        <view class="item-price">¥{{item.price}}</view>
        <view class="item-publisher">
          <image class="publisher-avatar" src="{{item.userAvatar || '../../images/avatar.png'}}" />
          <text class="publisher-name">{{item.userName}}</text>
        </view>
      </view>
    </view>

    <view class="loading-more" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>

    <view class="no-more" wx:if="{{!loading && !hasMore}}">
      <text>没有更多了</text>
    </view>

    <view class="empty-state" wx:if="{{items.length === 0 && !loading}}">
      <image class="empty-icon" src="../../images/default-goods-image.png" />
      <text class="empty-text">暂无二手物品</text>
      <text class="empty-hint">快去发布你的第一件物品吧</text>
    </view>
  </scroll-view>
</view>