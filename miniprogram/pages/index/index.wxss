page {
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.container {
  padding: 20rpx;
}

.user-bar {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #f0f0f0;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.user-desc {
  font-size: 24rpx;
  color: #999;
}

.user-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 10rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 40rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.search-input {
  flex: 1;
  height: 70rpx;
  font-size: 28rpx;
  color: #333;
}

.search-btn {
  height: 56rpx;
  padding: 0 30rpx;
  background-color: #07c160;
  color: #fff;
  border-radius: 28rpx;
  font-size: 28rpx;
  line-height: 56rpx;
}

.category-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.category-list {
  display: inline-flex;
  padding: 10rpx 0;
}

.category-item {
  display: inline-block;
  padding: 15rpx 30rpx;
  margin-right: 20rpx;
  background-color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.category-item.active {
  background-color: #07c160;
  color: #fff;
}

.item-list {
  height: calc(100vh - 360rpx);
}

.filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 10rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.time-range {
  display: flex;
  align-items: center;
}

.time-item {
  padding: 10rpx 20rpx;
  margin-right: 10rpx;
  font-size: 24rpx;
  color: #666;
  border-radius: 20rpx;
}

.time-item:last-child {
  margin-right: 0;
}

.time-item.active {
  background-color: #e8f8ee;
  color: #07c160;
  font-weight: 500;
}

.sort-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 16rpx;
  font-size: 24rpx;
  color: #07c160;
  border-radius: 20rpx;
  background-color: #f5f5f5;
}

.sort-icon {
  margin-left: 6rpx;
  font-size: 22rpx;
}

.sort-icon.up {
  transform: rotate(180deg);
}

.item-card {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.item-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-category {
  font-size: 24rpx;
  color: #999;
}

.item-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.item-publisher {
  display: flex;
  align-items: center;
}

.publisher-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.publisher-name {
  font-size: 22rpx;
  color: #999;
}

.loading-more, .no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}