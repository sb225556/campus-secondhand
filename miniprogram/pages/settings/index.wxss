page {
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
}

.section-title {
  font-size: 26rpx;
  color: #999;
  padding: 20rpx 10rpx;
}

.setting-list {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-icon {
  width: 60rpx;
  height: 60rpx;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.setting-content {
  flex: 1;
}

.setting-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.setting-desc {
  font-size: 24rpx;
  color: #999;
}

.setting-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 10rpx;
}

.version-info {
  text-align: center;
  padding: 60rpx 0;
}

.version-text {
  font-size: 24rpx;
  color: #ccc;
}
