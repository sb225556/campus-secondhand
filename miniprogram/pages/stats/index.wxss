.container {
  padding: 20rpx;
  padding-bottom: 60rpx;
}

/* 概览卡片 */
.overview-grid {
  display: flex;
  flex-wrap: wrap;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.overview-card {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  box-sizing: border-box;
}

.card-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #07c160;
  line-height: 1.2;
}

.card-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 通用 section */
.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #07c160;
}

.section-body {
  width: 100%;
}

/* 本月数据 */
.month-stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}

.month-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.month-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #07c160;
}

.month-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.month-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #eee;
}

/* 分类统计 */
.category-bar {
  margin-bottom: 24rpx;
}

.category-bar:last-child {
  margin-bottom: 0;
}

.category-name {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.category-progress {
  width: 100%;
  height: 16rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.category-fill {
  height: 100%;
  background: linear-gradient(to right, #07c160, #1296db);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.category-info {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
}

.info-count {
  color: #333;
  font-weight: 500;
}

.info-avg {
  color: #07c160;
}

/* 7天趋势 */
.trend-chart {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 240rpx;
  padding: 20rpx 0;
}

.trend-bar {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 6rpx;
}

.trend-value {
  font-size: 20rpx;
  color: #07c160;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.trend-fill-wrap {
  width: 100%;
  height: 160rpx;
  display: flex;
  align-items: flex-end;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  overflow: hidden;
}

.trend-fill {
  width: 100%;
  background: linear-gradient(to top, #07c160, #1296db);
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.3s;
  min-height: 4rpx;
}

.trend-date {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 状态分布 */
.status-item {
  margin-bottom: 24rpx;
}

.status-item:last-child {
  margin-bottom: 0;
}

.status-label-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.status-label {
  font-size: 26rpx;
  color: #333;
}

.status-value {
  font-size: 26rpx;
  color: #07c160;
  font-weight: bold;
}

.status-bar {
  width: 100%;
  height: 16rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.status-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.status-fill.on-sale {
  background-color: #07c160;
}

.status-fill.sold {
  background-color: #999;
}

/* 空状态 */
.empty-block {
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #ccc;
}

/* 底部 */
.footer-tip {
  text-align: center;
  font-size: 22rpx;
  color: #ccc;
  margin-top: 40rpx;
}
