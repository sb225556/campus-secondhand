page {
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
}

.item-list {
  height: calc(100vh - 100rpx);
}

.item-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
}

.item-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.item-category {
  font-size: 24rpx;
  color: #999;
}

.item-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.item-status {
  font-size: 24rpx;
  color: #07c160;
}

.item-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 15rpx;
}

.action-btn {
  padding: 15rpx 20rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
}

.action-btn.edit {
  background-color: #f0f0f0;
  color: #666;
}

.action-btn.delete {
  background-color: #fff1f0;
  color: #ff4d4f;
}

.loading-more, .no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.empty-btn {
  padding: 20rpx 60rpx;
  background-color: #07c160;
  color: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
}