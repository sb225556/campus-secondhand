page {
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.container {
  padding: 20rpx;
}

.form-item {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 70rpx;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #eee;
}

.price-input-wrap {
  display: flex;
  align-items: center;
}

.price-symbol {
  font-size: 32rpx;
  color: #333;
  margin-right: 10rpx;
}

.price-input {
  flex: 1;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  padding: 15rpx;
  box-sizing: border-box;
}

.category-picker {
  margin-top: 15rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 70rpx;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #eee;
}

.picker-arrow {
  width: 30rpx;
  height: 30rpx;
  transform: rotate(90deg);
}

.image-upload {
  margin-top: 15rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.image-item {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
}

.upload-btn {
  width: 180rpx;
  height: 180rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 48rpx;
  color: #999;
}

.upload-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 15rpx;
}

.submit-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
}