page {
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.image-swiper {
  width: 100%;
  height: 600rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.item-info {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 20rpx;
}

.item-header {
  margin-bottom: 20rpx;
}

.item-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.item-price {
  font-size: 44rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.item-meta {
  display: flex;
  gap: 40rpx;
}

.meta-item {
  display: flex;
  align-items: center;
}

.meta-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 10rpx;
}

.meta-value {
  font-size: 26rpx;
  color: #333;
}

.meta-value.available {
  color: #07c160;
}

.meta-value.sold {
  color: #999;
}

.item-divider {
  height: 20rpx;
  background-color: #f5f5f5;
  margin: 0 -20rpx;
}

.section {
  padding: 20rpx 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.publisher-info {
  display: flex;
  align-items: center;
}

.publisher-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.publisher-name {
  font-size: 28rpx;
  color: #333;
}

.contact-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.contact-value {
  font-size: 28rpx;
  color: #333;
}

.contact-copy {
  font-size: 26rpx;
  color: #07c160;
  padding: 10rpx 20rpx;
  border: 1rpx solid #07c160;
  border-radius: 20rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ddd;
  border-radius: 35rpx;
  margin-right: 20rpx;
}

.action-btn.primary {
  background-color: #07c160;
  border-color: #07c160;
}

.action-btn.primary .action-text {
  color: #fff;
}

.heart-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 10rpx;
  background-color: #999;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
}

.heart-icon.active {
  background-color: #ff4d4f;
}

.action-text {
  font-size: 28rpx;
  color: #333;
}